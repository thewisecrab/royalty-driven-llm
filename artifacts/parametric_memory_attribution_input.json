  "training_sources": [
    {
      "chunk_id": "arjun-provenance-ledger:c1",
      "content": "Every royalty bearing AI answer should have a provenance record. The record should include source identifiers, content hashes, retrieval scores, output citations, payout weights, and an event hash that allows auditors to replay the attribution. Hashes do not prove legal ownership by themselves, but they do prove that a payout was tied to a specific registered text at a specific point in the ledger.",
      "creator_id": "arjun",
      "creator_name": "Arjun Rao",
      "source_id": "arjun-provenance-ledger",
      "source_role": "training_candidate",
      "source_uri": "registered://works/arjun-provenance-ledger",
      "title": "Provenance Ledgers for AI Outputs",
      "work_id": "arjun-provenance-ledger"
    },
    {
      "chunk_id": "maya-youtube-style-pool:c1",
      "content": "A creator platform can reserve a fixed share of revenue for contributors and distribute that creator pool according to measurable usage. Video platforms often use views, watch time, eligibility rules, and policy compliance to decide which creators share revenue. A royalty driven LLM should use the same business idea but replace video views with generation events, retrieved source use, and output support.",
      "creator_id": "maya",
      "creator_name": "Maya Sen",
      "source_id": "maya-youtube-style-pool",
      "source_role": "anti_source",
      "source_uri": "registered://works/maya-youtube-style-pool",
      "title": "Usage Pools for Creator Platforms",
      "work_id": "maya-youtube-style-pool"
    }
  ]
