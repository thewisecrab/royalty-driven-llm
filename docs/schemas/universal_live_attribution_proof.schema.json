{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.example/schemas/universal_live_attribution_proof.schema.json",
  "title": "RDLLM Universal Live Attribution Proof",
  "type": "object",
  "required": [
    "universal_live_attribution_proof_version",
    "schema",
    "created_at",
    "issuer",
    "policy",
    "well_known",
    "artifact_bindings",
    "live_source_rows",
    "knowledge_source_mode_rows",
    "footer_surface_rows",
    "negative_live_attribution_rows",
    "evidence_roots",
    "checks",
    "attribution_decision",
    "privacy",
    "summary",
    "universal_live_attribution_proof_hash",
    "signature"
  ],
  "additionalProperties": true,
  "properties": {
    "universal_live_attribution_proof_version": {
      "const": "rdllm-universal-live-attribution-proof/v1"
    },
    "schema": {
      "const": "docs/schemas/universal_live_attribution_proof.schema.json"
    },
    "created_at": { "type": "string" },
    "issuer": { "type": "string" },
    "policy": {
      "type": "object",
      "required": [
        "policy_version",
        "target_certification_level",
        "minimum_reference_distribution_level",
        "posthoc_citation_sufficient",
        "answer_accuracy_without_source_attribution_sufficient",
        "source_footer_required_before_release",
        "creator_settlement_requires_live_proof",
        "knowledge_source_classification_required",
        "attribution_suppression_blocks_release"
      ],
      "properties": {
        "policy_version": {
          "const": "rdllm-universal-live-attribution-proof-policy/v1"
        },
        "target_certification_level": { "const": "RDLLM-L165" },
        "minimum_reference_distribution_level": { "const": "RDLLM-L164" },
        "minimum_factual_confidence": { "type": "number", "minimum": 0 },
        "minimum_utility_score": { "type": "number", "minimum": 0 },
        "posthoc_citation_sufficient": { "const": false },
        "answer_accuracy_without_source_attribution_sufficient": {
          "const": false
        },
        "source_footer_required_before_release": { "const": true },
        "creator_settlement_requires_live_proof": { "const": true },
        "knowledge_source_classification_required": { "const": true },
        "attribution_suppression_blocks_release": { "const": true }
      }
    },
    "well_known": {
      "type": "object",
      "required": ["path", "returns"],
      "properties": {
        "path": {
          "const": "/.well-known/rdllm/universal-live-attribution-proof.json"
        },
        "returns": {
          "const": "rdllm-universal-live-attribution-proof/v1"
        }
      }
    },
    "artifact_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "artifact",
          "present",
          "artifact_hash",
          "payload_hash",
          "hash_reproducible"
        ],
        "properties": {
          "artifact": { "type": "string" },
          "present": { "type": "boolean" },
          "artifact_hash": { "type": "string" },
          "payload_hash": { "type": "string" },
          "hash_reproducible": { "type": "boolean" },
          "status": { "type": "string" },
          "level": { "type": "string" }
        }
      }
    },
    "live_source_rows": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "source_hash",
          "footer_row_hash",
          "claim_provenance_hash",
          "influence_hash",
          "source_identity_hash",
          "confidence_hash",
          "settlement_hash",
          "knowledge_source_mode",
          "visible_in_footer",
          "identity_verified",
          "claim_support_verified",
          "current_turn_or_memory_path_verified",
          "causal_utility_verified",
          "factual_confidence_accepted",
          "license_or_escrow_resolved",
          "settlement_weight_bound",
          "private_payloads_excluded",
          "factual_confidence",
          "utility_score",
          "attribution_weight"
        ],
        "properties": {
          "source_hash": { "type": "string" },
          "footer_row_hash": { "type": "string" },
          "claim_provenance_hash": { "type": "string" },
          "influence_hash": { "type": "string" },
          "source_identity_hash": { "type": "string" },
          "confidence_hash": { "type": "string" },
          "settlement_hash": { "type": "string" },
          "knowledge_source_mode": {
            "enum": [
              "current_turn_retrieval",
              "tool_observation",
              "conversation_memory",
              "persistent_memory",
              "parametric_memory",
              "post_training_signal",
              "residual_corpus_value",
              "no_source_abstention"
            ]
          },
          "visible_in_footer": { "type": "boolean" },
          "identity_verified": { "type": "boolean" },
          "claim_support_verified": { "type": "boolean" },
          "current_turn_or_memory_path_verified": { "type": "boolean" },
          "causal_utility_verified": { "type": "boolean" },
          "factual_confidence_accepted": { "type": "boolean" },
          "license_or_escrow_resolved": { "type": "boolean" },
          "settlement_weight_bound": { "type": "boolean" },
          "private_payloads_excluded": { "type": "boolean" },
          "factual_confidence": { "type": "number", "minimum": 0 },
          "utility_score": { "type": "number", "minimum": 0 },
          "attribution_weight": { "type": "number", "minimum": 0 },
          "settlement_weight": { "type": "number", "minimum": 0 }
        }
      }
    },
    "knowledge_source_mode_rows": {
      "type": "object",
      "required": [
        "current_turn_retrieval",
        "tool_observation",
        "conversation_memory",
        "persistent_memory",
        "parametric_memory",
        "post_training_signal",
        "residual_corpus_value",
        "no_source_abstention"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "classifier_hash",
          "calibration_hash",
          "evidence_path_hash",
          "negative_control_hash",
          "mode_supported",
          "classifier_calibrated",
          "negative_control_passed",
          "footer_policy_enforced",
          "settlement_policy_bound"
        ],
        "properties": {
          "classifier_hash": { "type": "string" },
          "calibration_hash": { "type": "string" },
          "evidence_path_hash": { "type": "string" },
          "negative_control_hash": { "type": "string" },
          "mode_supported": { "type": "boolean" },
          "classifier_calibrated": { "type": "boolean" },
          "negative_control_passed": { "type": "boolean" },
          "footer_policy_enforced": { "type": "boolean" },
          "settlement_policy_bound": { "type": "boolean" }
        }
      }
    },
    "footer_surface_rows": {
      "type": "object",
      "required": [
        "api_json",
        "markdown",
        "html",
        "streaming_final",
        "copy_export"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "surface_hash",
          "rendered_footer_hash",
          "live_proof_binding_hash",
          "copy_export_hash",
          "source_footer_visible",
          "live_proof_hash_embedded",
          "claim_markers_preserved",
          "source_order_preserved",
          "verification_link_available",
          "copy_export_preserves_footer"
        ],
        "properties": {
          "surface_hash": { "type": "string" },
          "rendered_footer_hash": { "type": "string" },
          "live_proof_binding_hash": { "type": "string" },
          "copy_export_hash": { "type": "string" },
          "source_footer_visible": { "type": "boolean" },
          "live_proof_hash_embedded": { "type": "boolean" },
          "claim_markers_preserved": { "type": "boolean" },
          "source_order_preserved": { "type": "boolean" },
          "verification_link_available": { "type": "boolean" },
          "copy_export_preserves_footer": { "type": "boolean" }
        }
      }
    },
    "negative_live_attribution_rows": {
      "type": "object",
      "required": [
        "decorative_citation_without_influence",
        "right_answer_wrong_source",
        "fabricated_source_identity",
        "hidden_payable_source",
        "low_confidence_source_released",
        "unsupported_parametric_memory_claim",
        "attribution_suppression",
        "stale_or_unavailable_source_released",
        "posthoc_footer_added_after_generation",
        "provider_strips_live_proof",
        "settlement_released_without_live_proof",
        "private_payload_leak"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "fixture_hash",
          "expected_reject",
          "observed_reject",
          "response_blocked",
          "footer_reliance_blocked",
          "settlement_held",
          "public_status_marked_failed"
        ],
        "properties": {
          "fixture_hash": { "type": "string" },
          "expected_reject": { "type": "boolean" },
          "observed_reject": { "type": "boolean" },
          "response_blocked": { "type": "boolean" },
          "footer_reliance_blocked": { "type": "boolean" },
          "settlement_held": { "type": "boolean" },
          "public_status_marked_failed": { "type": "boolean" }
        }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "core_artifacts_bound",
        "reference_distribution_l164_ready",
        "all_live_sources_attributed",
        "no_decorative_citations",
        "no_hidden_payable_sources",
        "factual_confidence_gate_passed",
        "knowledge_source_modes_covered",
        "footer_surfaces_preserve_live_proof",
        "settlement_participation_bound",
        "attribution_suppression_absent",
        "negative_live_fixtures_reject",
        "live_attribution_proof_signed"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "attribution_decision": {
      "type": "object",
      "required": [
        "live_attribution_ready",
        "response_release_allowed",
        "source_footer_reliance_allowed",
        "creator_settlement_release_allowed",
        "posthoc_footer_only_rejected",
        "failure_modes"
      ],
      "properties": {
        "live_attribution_ready": { "type": "boolean" },
        "response_release_allowed": { "type": "boolean" },
        "source_footer_reliance_allowed": { "type": "boolean" },
        "creator_settlement_release_allowed": { "type": "boolean" },
        "posthoc_footer_only_rejected": { "const": true },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "privacy": {
      "type": "object",
      "required": [
        "raw_prompt_disclosed",
        "raw_answer_disclosed",
        "raw_source_text_disclosed",
        "private_fields_absent",
        "private_strings_absent",
        "public_rows_are_hash_and_status_only"
      ],
      "properties": {
        "raw_prompt_disclosed": { "const": false },
        "raw_answer_disclosed": { "const": false },
        "raw_source_text_disclosed": { "const": false },
        "private_fields_absent": { "type": "boolean" },
        "private_strings_absent": { "type": "boolean" },
        "public_rows_are_hash_and_status_only": { "const": true }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "target_certification_level",
        "minimum_reference_distribution_level",
        "live_source_count",
        "ready_live_source_count",
        "knowledge_source_mode_count",
        "footer_surface_count",
        "negative_live_failure_count",
        "failure_mode_count",
        "signed_live_attribution_proof",
        "privacy_preserved"
      ],
      "properties": {
        "status": { "enum": ["ready", "blocked"] },
        "target_certification_level": { "const": "RDLLM-L165" },
        "minimum_reference_distribution_level": { "const": "RDLLM-L164" },
        "live_source_count": { "type": "integer", "minimum": 0 },
        "ready_live_source_count": { "type": "integer", "minimum": 0 },
        "knowledge_source_mode_count": { "const": 8 },
        "footer_surface_count": { "const": 5 },
        "negative_live_failure_count": { "const": 12 },
        "failure_mode_count": { "type": "integer", "minimum": 0 },
        "signed_live_attribution_proof": { "const": true },
        "privacy_preserved": { "type": "boolean" }
      }
    },
    "universal_live_attribution_proof_hash": {
      "type": "string",
      "minLength": 32
    },
    "signature": {
      "type": "object",
      "required": ["issuer", "algorithm", "value"],
      "properties": {
        "issuer": { "type": "string" },
        "algorithm": { "const": "HMAC-SHA256" },
        "value": { "type": "string", "minLength": 32 }
      }
    }
  }
}
