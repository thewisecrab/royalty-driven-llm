{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.local/schemas/universal_content_credential.schema.json",
  "title": "RDLLM Universal Content Credential",
  "type": "object",
  "required": [
    "credential_version",
    "issuer",
    "created_at",
    "credential_policy",
    "artifact_bindings",
    "content_subject",
    "source_attribution_rows",
    "payout_eligibility_rows",
    "provider_invocation_rows",
    "output_credential_rows",
    "durable_signal_rows",
    "public_verification_rows",
    "commitments",
    "checks",
    "credential_decision",
    "schemas",
    "summary",
    "privacy",
    "universal_content_credential_hash",
    "signature"
  ],
  "properties": {
    "credential_version": {
      "const": "rdllm-universal-content-credential/v1"
    },
    "issuer": { "type": "string" },
    "created_at": { "type": "string" },
    "credential_policy": {
      "type": "object",
      "required": [
        "profile",
        "target_certification_level",
        "minimum_input_level",
        "required_bindings",
        "compatible_with",
        "raw_prompt_output_source_or_payment_text_must_not_be_embedded"
      ],
      "additionalProperties": true
    },
    "artifact_bindings": {
      "type": "object",
      "required": [
        "artifact_count",
        "artifact_binding_root",
        "bindings"
      ],
      "additionalProperties": true
    },
    "content_subject": {
      "type": "object",
      "required": [
        "content_id",
        "content_kind",
        "media_type",
        "modality",
        "language",
        "output_hash",
        "rendered_output_hash",
        "response_envelope_hash",
        "answer_provenance_card_hash",
        "output_provenance_binding_hash",
        "output_provenance_subject_hash",
        "universal_invocation_witness_hash",
        "discovery_manifest_hash",
        "source_count",
        "payout_row_count",
        "provider_invocation_count",
        "source_root",
        "payout_root",
        "provider_invocation_root",
        "content_subject_hash"
      ],
      "additionalProperties": true
    },
    "source_attribution_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_label",
          "work_id",
          "creator_id",
          "source_uri_hash",
          "supported_claim_count",
          "license_status",
          "royalty_status",
          "footer_row_hash",
          "answer_card_source_hash",
          "source_preview_row_hash",
          "evidence_locator_row_hash",
          "citation_url_health_row_hash",
          "source_credential_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "payout_eligibility_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "creator_id",
          "work_id",
          "event_count",
          "visible_source_count",
          "supported_claim_count",
          "source_access_count",
          "payout_state",
          "total_payout",
          "royalty_statement_hash",
          "payout_credential_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "provider_invocation_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "invocation_id_hash",
          "request_id_hash",
          "provider_family",
          "route_id_hash",
          "native_model_hash",
          "coverage_call_hash",
          "provider_receipt_hash",
          "egress_event_bound",
          "independent_witness_count",
          "nonrepudiation_complete",
          "provider_invocation_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "output_credential_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "manifest_profile",
          "manifest_id",
          "assertion_label",
          "provenance_pointer",
          "bound_output_hash",
          "bound_rendered_output_hash",
          "bound_content_subject_hash",
          "bound_universal_invocation_witness_hash",
          "bound_source_root",
          "bound_payout_root",
          "bound_provider_invocation_root",
          "bound_artifact_root",
          "credential_payload_hash",
          "signature_algorithm",
          "signature",
          "verified",
          "credential_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "durable_signal_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "signal_type",
          "verifier",
          "purpose",
          "bound_output_hash",
          "bound_content_subject_hash",
          "confidence",
          "signal_present",
          "raw_output_text_disclosed",
          "signal_id",
          "signal_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "public_verification_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "path",
          "verifier_command",
          "bound_content_subject_hash",
          "required",
          "verification_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "commitments": {
      "type": "object",
      "required": [
        "content_subject_hash",
        "artifact_binding_root",
        "source_root",
        "payout_root",
        "provider_invocation_root",
        "output_credential_root",
        "durable_signal_root",
        "public_verification_root"
      ],
      "additionalProperties": { "type": "string" }
    },
    "checks": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "credential_decision": {
      "type": "object",
      "required": [
        "decision",
        "failure_modes",
        "all_required_bindings_present"
      ],
      "additionalProperties": true
    },
    "schemas": {
      "type": "object",
      "required": [
        "universal_content_credential",
        "response_envelope",
        "answer_provenance_card",
        "grounded_source_footer",
        "output_provenance_binding_report",
        "universal_invocation_witness",
        "royalty_statement",
        "discovery_manifest"
      ],
      "additionalProperties": { "type": "string" }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "target_certification_level",
        "minimum_input_level",
        "content_subject_hash",
        "output_hash",
        "source_count",
        "payout_row_count",
        "provider_invocation_count",
        "credential_count",
        "durable_signal_count",
        "public_verification_surface_count",
        "failed_check_count",
        "artifact_count",
        "offline_verification_supported",
        "raw_prompt_output_source_or_payment_text_disclosed"
      ],
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": [
        "raw_prompt_text_disclosed",
        "raw_output_text_disclosed",
        "raw_source_text_disclosed",
        "private_payment_details_disclosed",
        "credential_uses_hashes_footers_public_status_and_verifier_paths",
        "private_field_findings"
      ],
      "additionalProperties": true
    },
    "universal_content_credential_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": [
        "algorithm",
        "issuer",
        "value"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
