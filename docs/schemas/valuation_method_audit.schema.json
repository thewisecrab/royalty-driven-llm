{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.example/schemas/valuation_method_audit.schema.json",
  "title": "RDLLM Valuation Method Audit",
  "type": "object",
  "required": [
    "version",
    "issued_at",
    "issuer",
    "case",
    "policy",
    "subject",
    "method_rows",
    "benchmark_case_rows",
    "duplicate_group_rows",
    "stability_group_rows",
    "scorecard",
    "checks",
    "privacy",
    "schemas",
    "summary",
    "report_hash",
    "signature"
  ],
  "properties": {
    "version": {
      "const": "rdllm-valuation-method-audit/v1"
    },
    "issued_at": {
      "type": "string"
    },
    "issuer": {
      "type": "string"
    },
    "case": {
      "type": "object",
      "required": ["case_id", "status"],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "status": {
          "enum": ["ready", "needs_review"]
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "required_case_types",
        "max_mean_absolute_error",
        "minimum_rank_agreement",
        "max_antidocument_score",
        "max_duplicate_group_share",
        "max_stability_delta",
        "minimum_payable_confidence",
        "minimum_positive_score",
        "require_method_commitments",
        "require_privacy_proof_commitment",
        "require_residual_scope_separation"
      ],
      "additionalProperties": true
    },
    "subject": {
      "type": "object",
      "required": [
        "residual_corpus_royalty_report_hash",
        "residual_corpus_royalty_version",
        "residual_corpus_royalty_status",
        "valuation_row_count",
        "valuation_methods_used",
        "valuation_methods_audited",
        "target_input_level"
      ],
      "properties": {
        "target_input_level": {
          "const": "RDLLM-L95"
        }
      },
      "additionalProperties": true
    },
    "method_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method_id",
          "method_family",
          "method_version",
          "valuation_code_hash",
          "training_value_evidence_root",
          "benchmark_suite_hash",
          "privacy_proof_hash",
          "proof_system",
          "method_commitment_complete",
          "privacy_commitment_complete",
          "zk_or_hash_verifiability_declared",
          "method_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "benchmark_case_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "benchmark_case_id",
          "case_type",
          "work_id",
          "method_id",
          "expected_decision",
          "actual_decision",
          "expected_score",
          "observed_score",
          "score_abs_error",
          "confidence_score",
          "evidence_hash",
          "checks",
          "benchmark_case_hash"
        ],
        "additionalProperties": true
      }
    },
    "duplicate_group_rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stability_group_rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "scorecard": {
      "type": "object",
      "required": [
        "benchmark_case_count",
        "case_types_covered",
        "mean_absolute_error",
        "rank_agreement",
        "failed_case_count",
        "duplicate_group_count",
        "stability_group_count"
      ],
      "additionalProperties": true
    },
    "checks": {
      "type": "object",
      "required": [
        "residual_report_hash_reproducible",
        "residual_report_ready_l95",
        "residual_scope_separates_visible_and_diffuse_value",
        "required_benchmark_case_types_covered",
        "benchmark_accuracy_within_threshold",
        "rank_agreement_within_threshold",
        "all_benchmark_cases_pass",
        "anti_documents_rejected",
        "duplicate_inflation_guard_passed",
        "confidence_calibration_passed",
        "score_stability_passed",
        "valuation_methods_cover_residual_rows",
        "valuation_methods_have_commitments",
        "privacy_proof_commitments_present",
        "private_text_not_disclosed"
      ],
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "privacy": {
      "type": "object"
    },
    "schemas": {
      "type": "object",
      "required": ["valuation_method_audit", "residual_corpus_royalty_report"]
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "target_certification_level",
        "benchmark_case_count",
        "case_type_count",
        "mean_absolute_error",
        "rank_agreement",
        "failed_case_count",
        "method_count",
        "valuation_method_audited",
        "valuation_methods_cover_residual_rows",
        "residual_report_bound",
        "anti_gaming_guards_passed",
        "privacy_verifiability_supported"
      ],
      "properties": {
        "status": {
          "enum": ["ready", "needs_review"]
        },
        "target_certification_level": {
          "const": "RDLLM-L96"
        }
      },
      "additionalProperties": true
    },
    "report_hash": {
      "type": "string"
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
