    },
    "policy": {
      "type": "object",
      "required": [
        "policy_version",
        "target_certification_level",
        "minimum_runtime_route_binding_level",
        "minimum_source_footer_enforcement_level",
        "minimum_source_grounded_response_level",
        "minimum_citation_verification_level",
        "link_health_relevance_and_fact_support_required",
        "footer_rows_must_be_visible_and_machine_readable",
        "used_sources_must_be_displayed_or_escrowed",
