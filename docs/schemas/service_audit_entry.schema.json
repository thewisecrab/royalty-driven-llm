{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.example/schemas/service_audit_entry.schema.json",
  "title": "RDLLM Service Audit Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "request_id",
    "timestamp",
    "status",
    "event_id",
    "event_hash",
    "source_footer_hash",
    "display_hash",
    "source_count",
    "audit_error_count",
    "previous_entry_hash",
    "entry_hash"
  ],
  "properties": {
    "schema": { "const": "rdllm-service-audit-entry/v1" },
    "request_id": { "type": "string", "minLength": 1 },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "status": { "enum": ["ready", "blocked"] },
    "event_id": {
      "type": "string",
      "pattern": "^$|^evt_[0-9a-f]{16}$"
    },
    "event_hash": { "$ref": "#/$defs/hash64_or_empty" },
    "source_footer_hash": { "$ref": "#/$defs/hash64_or_empty" },
    "display_hash": { "$ref": "#/$defs/hash64_or_empty" },
    "source_count": { "type": "integer", "minimum": 0 },
    "audit_error_count": { "type": "integer", "minimum": 0 },
    "previous_entry_hash": { "$ref": "#/$defs/hash64_or_empty" },
    "entry_hash": { "$ref": "#/$defs/hash64" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "event_id": { "pattern": "^evt_[0-9a-f]{16}$" },
          "event_hash": { "$ref": "#/$defs/hash64" },
          "source_footer_hash": { "$ref": "#/$defs/hash64" },
          "display_hash": { "$ref": "#/$defs/hash64" },
          "audit_error_count": { "const": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "audit_error_count": { "minimum": 1 }
        }
      }
    }
  ],
  "$defs": {
    "hash64": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hash64_or_empty": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    }
  }
}
