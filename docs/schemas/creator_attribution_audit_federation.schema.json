{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.local/schemas/creator_attribution_audit_federation.schema.json",
  "title": "RDLLM Creator Attribution Audit Federation",
  "type": "object",
  "required": [
    "version",
    "issued_at",
    "issuer",
    "case",
    "participant_rows",
    "federated_surface_rows",
    "federated_creator_work_rows",
    "identity_conflict_rows",
    "commitments",
    "checks",
    "privacy",
    "schemas",
    "summary",
    "creator_attribution_audit_federation_hash",
    "signature"
  ],
  "additionalProperties": true,
  "properties": {
    "version": { "const": "rdllm-creator-attribution-audit-federation/v1" },
    "issued_at": { "type": "string" },
    "issuer": { "type": "string" },
    "case": {
      "type": "object",
      "required": ["case_id", "minimum_certification_level", "query_federation"],
      "additionalProperties": true,
      "properties": {
        "minimum_certification_level": { "const": "RDLLM-L110" }
      }
    },
    "participant_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "provider_id",
          "creator_attribution_audit_index_hash",
          "query_hash",
          "index_ready",
          "index_target_level",
          "participant_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "federated_surface_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider_id",
          "provider_source_label_namespace",
          "participant_index_hash",
          "surface",
          "artifact_name",
          "federated_surface_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "federated_creator_work_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "creator_id",
          "work_id",
          "provider_ids",
          "provider_count",
          "federated_creator_work_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "identity_conflict_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["work_id", "creator_id_hashes", "conflict_type", "conflict_row_hash"],
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "minimum_two_participants_present",
        "participant_provider_ids_unique",
        "all_participant_indexes_ready_l110",
        "participant_query_hashes_match",
        "all_participant_indexes_hash_reproducible",
        "participant_provider_cards_declare_creator_audit",
        "participant_discovery_paths_present",
        "federation_artifacts_bound_when_present",
        "source_label_namespaces_are_provider_scoped",
        "duplicate_surface_rows_not_double_counted",
        "creator_work_rows_merge_multiple_providers",
        "no_unresolved_creator_identity_conflicts",
        "notices_and_private_text_not_disclosed"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "privacy": {
      "type": "object",
      "required": [
        "query_terms_disclosed",
        "raw_prompt_disclosed",
        "raw_answer_disclosed",
        "raw_source_text_disclosed",
        "raw_feedback_text_disclosed",
        "raw_notice_text_disclosed",
        "raw_license_text_disclosed",
        "raw_payment_data_disclosed"
      ],
      "additionalProperties": true
    },
    "schemas": {
      "type": "object",
      "required": [
        "creator_attribution_audit_federation",
        "creator_attribution_audit_index",
        "federation_handshake",
        "attribution_exchange"
      ],
      "additionalProperties": { "type": "string" }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "target_certification_level",
        "minimum_certification_level",
        "participant_count",
        "provider_count",
        "federated_surface_row_count",
        "federated_creator_work_count",
        "identity_conflict_count",
        "failed_check_count",
        "creator_audit_federation_ready",
        "privacy_preserved"
      ],
      "additionalProperties": true,
      "properties": {
        "status": { "enum": ["ready", "blocked"] },
        "target_certification_level": { "const": "RDLLM-L111" },
        "minimum_certification_level": { "const": "RDLLM-L110" },
        "participant_count": { "type": "integer", "minimum": 0 },
        "provider_count": { "type": "integer", "minimum": 0 },
        "federated_surface_row_count": { "type": "integer", "minimum": 0 },
        "federated_creator_work_count": { "type": "integer", "minimum": 0 },
        "identity_conflict_count": { "type": "integer", "minimum": 0 },
        "failed_check_count": { "type": "integer", "minimum": 0 },
        "creator_audit_federation_ready": { "type": "boolean" },
        "privacy_preserved": { "type": "boolean" }
      }
    },
    "creator_attribution_audit_federation_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
  }
}
