{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.example/schemas/content_protocol_ingestion_report.schema.json",
  "title": "RDLLM Content Protocol Ingestion Report",
  "type": "object",
  "required": [
    "version",
    "issued_at",
    "issuer",
    "case",
    "policy",
    "artifact_bindings",
    "protocol_rows",
    "source_usage_rows",
    "coverage_rows",
    "checks",
    "privacy",
    "schemas",
    "summary",
    "protocol_ingestion_report_hash",
    "signature"
  ],
  "properties": {
    "version": {
      "const": "rdllm-content-protocol-ingestion/v1"
    },
    "issued_at": {
      "type": "string"
    },
    "issuer": {
      "type": "string"
    },
    "case": {
      "type": "object",
      "required": ["case_id", "status"],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "status": {
          "enum": ["ready", "needs_review"]
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "require_protocol_record_for_direct_sources",
        "require_supported_external_protocol",
        "require_protocol_terms_allow_use",
        "require_creator_contract_matches_protocol",
        "require_source_lease_matches_protocol",
        "require_protocol_hash_replay",
        "require_denied_or_missing_protocol_escrowed"
      ],
      "additionalProperties": true
    },
    "artifact_bindings": {
      "type": "object",
      "required": [
        "creator_license_contract_hash",
        "source_access_lease_report_hash",
        "source_availability_report_hash",
        "evidence_region_binding_report_hash",
        "creator_license_contract_hash_reproducible",
        "source_access_lease_hash_reproducible",
        "source_availability_hash_reproducible",
        "evidence_region_binding_hash_reproducible"
      ],
      "additionalProperties": true
    },
    "protocol_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "protocol_record_id",
          "protocol",
          "protocol_supported",
          "record_uri",
          "source_uri",
          "work_id",
          "content_hash",
          "allowed_uses",
          "prohibited_uses",
          "payment_type",
          "minimum_creator_pool_rate",
          "attribution_required",
          "royalty_required",
          "notice_hash",
          "raw_notice_disclosed",
          "protocol_record_hash",
          "record_hash_matches_declared"
        ],
        "additionalProperties": true
      }
    },
    "source_usage_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_usage_id",
          "source_label",
          "work_id",
          "chunk_id",
          "source_uri",
          "content_hash",
          "usage_purpose",
          "settlement_status",
          "direct_settlement",
          "escrowed"
        ],
        "additionalProperties": true
      }
    },
    "coverage_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_usage_id",
          "source_label",
          "work_id",
          "chunk_id",
          "usage_purpose",
          "direct_settlement",
          "escrowed",
          "matching_protocol_count",
          "supported_protocol_count",
          "selected_protocol_record_id",
          "selected_protocol",
          "protocol_allows_use",
          "creator_contract_matches_protocol",
          "source_lease_matches_protocol",
          "source_access_lease_covered",
          "covered_for_protocol_ingestion",
          "missing_or_denied_protocol_escrowed",
          "coverage_row_hash"
        ],
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "artifact_hashes_reproducible",
        "supported_external_protocols_present",
        "protocol_record_hashes_reproducible",
        "direct_sources_have_protocol_records",
        "direct_protocol_terms_allow_use",
        "direct_protocol_terms_preserved_in_contract",
        "direct_protocol_terms_preserved_in_source_lease",
        "no_direct_settlement_without_protocol_permission",
        "denied_or_missing_protocol_use_escrowed",
        "private_text_not_disclosed",
        "direct_source_count_positive"
      ],
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "privacy": {
      "type": "object"
    },
    "schemas": {
      "type": "object",
      "required": [
        "content_protocol_ingestion_report",
        "creator_license_contract",
        "source_access_lease_report",
        "source_availability_report",
        "evidence_region_binding_report"
      ],
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "target_certification_level",
        "protocol_record_count",
        "supported_protocol_count",
        "supported_protocols",
        "source_usage_count",
        "direct_source_usage_count",
        "coverage_row_count",
        "covered_direct_source_count",
        "escrowed_missing_or_denied_protocol_count",
        "failed_check_count",
        "external_content_protocol_ingestion_supported",
        "rsl_comp_scp_bridge_supported",
        "privacy_preserved"
      ],
      "properties": {
        "status": {
          "enum": ["ready", "needs_review"]
        },
        "target_certification_level": {
          "const": "RDLLM-L99"
        }
      },
      "additionalProperties": true
    },
    "protocol_ingestion_report_hash": {
      "type": "string"
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
