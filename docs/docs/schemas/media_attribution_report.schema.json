{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rdllm.local/schemas/media_attribution_report.schema.json",
  "title": "RDLLM Media Attribution Report",
  "type": "object",
  "required": [
    "report_version",
    "issuer",
    "created_at",
    "policy",
    "economics",
    "matches",
    "royalty_shares",
    "commitments",
    "summary",
    "privacy",
    "report_hash",
    "signature"
  ],
  "properties": {
    "report_version": {
      "const": "rdllm-media-attribution/v1"
    },
    "issuer": { "type": "string" },
    "created_at": { "type": "string" },
    "policy": {
      "type": "object",
      "required": [
        "profile",
        "supported_media_types",
        "accept_threshold",
        "creator_pool_rate",
        "matching_signals"
      ],
      "additionalProperties": true
    },
    "economics": {
      "type": "object",
      "required": [
        "gross_revenue",
        "creator_pool",
        "item_pool",
        "payout_total",
        "escrow_total"
      ],
      "additionalProperties": true
    },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "input_id",
          "media_type",
          "input_hash",
          "perceptual_hash_commitment",
          "descriptor_hash",
          "ranked_candidates",
          "decision",
          "match_hash"
        ],
        "additionalProperties": true
      }
    },
    "royalty_shares": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "creator_id",
          "asset_id",
          "payout",
          "contribution_weight"
        ],
        "additionalProperties": true
      }
    },
    "commitments": {
      "type": "object",
      "required": [
        "media_corpus_root",
        "submitted_media_root",
        "match_root",
        "share_root"
      ],
      "additionalProperties": { "type": "string" }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "input_count",
        "matched_count",
        "escrow_count",
        "media_type_counts",
        "creator_count",
        "asset_count",
        "creator_pool_conserved",
        "multimodal_source_attribution"
      ],
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": [
        "raw_media_disclosed",
        "raw_descriptor_disclosed",
        "perceptual_hash_disclosed",
        "report_uses_hashes_scores_and_asset_ids"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "report_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
