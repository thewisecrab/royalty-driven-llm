      "type": "object",
      "required": [
        "event_count",
        "source_access_count",
        "source_reference_count",
        "claim_support_count",
        "paid_source_count",
        "escrow_share_count",
        "gap_issue_count",
        "accounted_access_count",
        "accounted_access_ratio",
        "creator_pool_total"
      ],
      "properties": {
        "event_count": { "type": "integer", "minimum": 0 },
        "source_access_count": { "type": "integer", "minimum": 0 },
        "accounted_access_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "evidence_roots": {
      "type": "object",
      "required": [
        "ledger_root",
        "event_root",
        "source_access_root",
        "source_reference_root",
        "claim_support_root",
        "royalty_share_root",
        "grounding_quality_root",
        "attribution_gap_root"
      ],
      "additionalProperties": { "type": "string" }
    },
    "privacy": {
      "type": "object",
      "required": [
        "prompt_text_disclosed",
        "answer_text_disclosed",
        "source_text_disclosed",
        "claim_evidence_text_disclosed",
        "matched_text_disclosed",
        "public_card_uses_counts_and_hash_roots"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "card_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
