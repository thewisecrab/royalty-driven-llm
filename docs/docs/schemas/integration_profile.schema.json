    "certification": {
      "type": "object",
      "required": [
        "report_hash",
        "status",
        "highest_level",
        "case_count",
        "passed",
        "failed",
        "score"
      ],
      "additionalProperties": true
    },
    "bound_artifacts": {
      "type": "object",
      "required": [
        "provider_card_hash",
        "certification_report_hash",
        "response_envelope_hash"
      ],
      "additionalProperties": true
    },
    "sample_response": {
      "type": "object",
      "required": [
        "event_id",
        "envelope_hash",
        "artifact_count",
        "source_count",
        "claim_count",
        "status"
      ],
      "additionalProperties": true
    },
    "readiness_checks": {
      "type": "object",
      "required": [
        "certification_level_at_least_l21",
        "all_required_public_surfaces_declared",
        "response_envelope_verified",
        "response_envelope_embeds_required_artifacts",
        "provider_card_hash_reproducible",
        "certification_report_hash_reproducible",
        "response_envelope_hash_reproducible",
        "assurance_bundle_includes_response_envelope",
        "certification_attestation_hash_reproducible"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "minimum_certification_level",
        "schema_count",
        "public_surface_count",
        "endpoint_count",
        "offline_verification_supported"
      ],
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": [
        "private_ledger_disclosed",
        "private_source_corpus_disclosed",
        "private_prompt_payload_disclosed",
        "profile_uses_hashes_and_contract_metadata"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "profile_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "issuer", "value"],
      "additionalProperties": true
    }
